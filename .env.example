# ─── API ────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api

# ─── Database (Prisma) ──────────────────────────
# Runtime: usar URL com pooler (-pooler no host) em produção
DATABASE_URL="postgresql://ponto:ponto@localhost:5432/ponto_digital?schema=public"
# Migrations: conexão direta (sem pooler). Em dev local pode ser igual à DATABASE_URL.
DATABASE_URL_UNPOOLED="postgresql://ponto:ponto@localhost:5432/ponto_digital?schema=public"

# ─── Deploy ─────────────────────────────────────
# Origem pública do app (obrigatório em produção para CSRF do adapter-node)
ORIGIN=http://localhost:3000

# ─── Auth ───────────────────────────────────────
VITE_JWT_SECRET=troque-por-um-segredo-real
VITE_SESSION_COOKIE_NAME=auth_token

# ─── App ────────────────────────────────────────
VITE_APP_NAME=Ponto Digital
